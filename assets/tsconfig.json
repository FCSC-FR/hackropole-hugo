// This files configures 'tsc' for type checking JavaScript
{
    "compilerOptions": {
        "baseUrl": ".",
        "strict": true,
        "noImplicitAny": true,
        "noImplicitThis": true,
        "noImplicitReturns": true,
        "alwaysStrict": true,
        "allowSyntheticDefaultImports": true,
        "checkJs": true,
        "allowJs": true,
        "module": "es2022",
        "target": "es2017",
        "noEmit": true
    }
}
